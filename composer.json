{
    "name": "laulamanapps/document-signer-docusign",
    "description": "DocuSign eSignature implementation of the document signer SDK.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "laulamanapps/document-signer-sdk": "^2.3",
        "guzzlehttp/guzzle": "^7.8",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "LauLamanApps\\DocumentSigner\\DocuSign\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LauLamanApps\\DocumentSigner\\DocuSign\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
